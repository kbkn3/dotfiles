# === GUI: shared ===
{{- range .homebrew.casks.shared }}
cask "{{ . }}"
{{- end }}

{{- if eq .profile "work" }}

# === GUI: work ===
{{- range .homebrew.casks.work }}
cask "{{ . }}"
{{- end }}
{{- end }}

{{- if eq .profile "personal" }}

# === GUI: personal ===
{{- range .homebrew.casks.personal }}
cask "{{ . }}"
{{- end }}
{{- end }}

