
# Kiro CLI pre block. Keep at the top of this file.
[[ -f "${HOME}/Library/Application Support/kiro-cli/shell/zshrc.pre.zsh" ]] && builtin source "${HOME}/Library/Application Support/kiro-cli/shell/zshrc.pre.zsh"

# history
setopt hist_ignore_dups
setopt EXTENDED_HISTORY
setopt hist_ignore_all_dups
setopt hist_ignore_space
setopt hist_verify
setopt hist_reduce_blanks
setopt hist_save_no_dups
setopt hist_no_store
setopt hist_expand
setopt share_history

# interactive
export LISTMAX=50
unsetopt bg_nice
setopt list_packed
setopt no_beep
unsetopt list_types

# === alias: modern CLI tools ===
# eza があれば ls 系を上書き
if (( $+commands[eza] )); then
  alias ls='eza --icons --git'
  alias ll='eza --icons --git -l'
  alias la='eza --icons --git -la'
  alias lt='eza --icons --git --tree --level=2'
else
  alias ls='ls -F --color=auto'
fi

# bat があれば cat を上書き（pager は無効化、less は通常通り）
if (( $+commands[bat] )); then
  alias cat='bat --paging=never'
  export BAT_THEME='ansi'
fi

# dust があれば du を上書き
if (( $+commands[dust] )); then
  alias du='dust'
fi

# setting
# 新規ファイル作成時のパーミッション
umask 022
# コアダンプを残さない
limit coredumpsize 0

# homebrew
eval "$(/opt/homebrew/bin/brew shellenv)"

# antigen
export _ANTIGEN_INSTALL_DIR=${HOME}/.local/bin
source "${HOME}/.config/zsh/antigen.zsh"

# Load the oh-my-zsh's library
# antigen use oh-my-zsh

antigen bundles <<EOBUNDLES
    # Bundles from the default repo (robbyrussell's oh-my-zsh)
    git
    # Syntax highlighting bundle.
    zsh-users/zsh-syntax-highlighting
    # Fish-like auto suggestions
    zsh-users/zsh-autosuggestions
    # Extra zsh completions
    zsh-users/zsh-completions
    # abbr
    olets/zsh-abbr@main
EOBUNDLES

# Tell antigen that you're done
antigen apply

# starship
eval "$(starship init zsh)"

# mise
if type mise &>/dev/null; then
  eval "$(mise activate zsh)"
  eval "$(mise activate --shims)"
fi

# zoxide で cd を置き換え（履歴ベースの fuzzy ジャンプ。`cd substring` で過去訪問先へ）
if (( $+commands[zoxide] )); then
  eval "$(zoxide init zsh --cmd cd)"
fi

# coreutils
export PATH="/opt/homebrew/opt/coreutils/libexec/gnubin:$PATH"

# ワークフロー関数を読み込み（fgc / fgl / fga / fkill / port / pro 等）
[[ -f "${HOME}/.custom/functions.sh" ]] && source "${HOME}/.custom/functions.sh"

# 端末ごとの設定を読み込み
# ローカル設定ファイルが存在する場合は読み込む
local_conf="${XDG_CONFIG_HOME:-$HOME/.config}/zsh/conf.d/hosts/local.zsh"
[[ -f "$local_conf" ]] && source "$local_conf"

# cmux app が提供する shell 関数 (worktree + AI agent ランチャー)
[[ -f "${HOME}/.cmux/cmux.sh" ]] && source "${HOME}/.cmux/cmux.sh"

{{- if eq .profile "work" }}

# AWS SSO プロファイル切り替え（aws-sso-switch / ass / Ctrl+P）
[[ -f "${HOME}/.local/bin/aws_sso_switch.zsh" ]] && source "${HOME}/.local/bin/aws_sso_switch.zsh"
{{- end }}

# Kiro CLI post block. Keep at the bottom of this file.
[[ -f "${HOME}/Library/Application Support/kiro-cli/shell/zshrc.post.zsh" ]] && builtin source "${HOME}/Library/Application Support/kiro-cli/shell/zshrc.post.zsh"
export PATH="$HOME/.local/bin:$PATH"
